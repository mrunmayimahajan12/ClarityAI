# Template only — copy to `.env` and fill in real values. Never commit `.env`.

# Postgres credentials (used by docker-compose to create the db service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=clarity

# Connection URL for the app.
# When running via Docker: use "db" as the host (the compose service name).
# When running locally outside Docker: use "localhost" and add ?sslmode=disable if needed.
DATABASE_URL=postgresql+psycopg://postgres:your-password-here@db:5432/clarity

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
DEBUG=true
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=15
CORS_ORIGINS=http://localhost:3000
